# api/endpoints.py
"""
Routes API pour le système RAG - Normes Électriques NFC 15-100
"""

from fastapi import APIRouter, HTTPException, Depends
from typing import List, Optional
import logging

from models.schemas import (
    AutocompleteRequest, AutocompleteResponse,
    ReformulateRequest, ReformulateResponse,
    NormeRequest, NormeResponse,
    SearchRequest, SearchResponse,
    Suggestion
)

logger = logging.getLogger(__name__)
router = APIRouter(prefix="/api/v1", tags=["rag"])


# ============================================================================
# SERVICE CONTAINER - Injection de dépendances
# ============================================================================

class ServiceContainer:
    """Container pour tous les services IA"""
    def __init__(self):
        self.suggestion_engine = None
        self.correction_pipeline = None
        self.vector_store = None
        self.prescriptions = None

# Instance globale
services = ServiceContainer()


# ============================================================================
# DEPENDENCIES
# ============================================================================

def get_suggestion_engine():
    if services.suggestion_engine is None:
        raise HTTPException(status_code=503, detail="SuggestionEngine non initialisé")
    return services.suggestion_engine


def get_correction_pipeline():
    if services.correction_pipeline is None:
        raise HTTPException(status_code=503, detail="CorrectionPipeline non initialisé")
    return services.correction_pipeline


def get_vector_store():
    if services.vector_store is None:
        raise HTTPException(status_code=503, detail="VectorStore non initialisé")
    return services.vector_store


def get_prescriptions():
    if services.prescriptions is None or len(services.prescriptions) == 0:
        raise HTTPException(status_code=503, detail="Prescriptions non chargées")
    return services.prescriptions


# ============================================================================
# ENDPOINTS
# ============================================================================

@router.post("/autocomplete", response_model=AutocompleteResponse)
async def autocomplete(
    request: AutocompleteRequest,
    engine = Depends(get_suggestion_engine)
):
    """
    Autocomplétion intelligente pour observations électriques
    
    - **query**: Texte à compléter (min 3 caractères)
    - **max_suggestions**: Nombre max de suggestions (défaut: 10)
    """
    try:
        logger.info(f"🔍 Autocomplete: '{request.query}'")
        
        if len(request.query.strip()) < 3:
            return AutocompleteResponse(
                query=request.query,
                suggestions=[],
                count=0
            )
        
        suggestions = engine.get_suggestions(
            user_input=request.query,
            max_suggestions=request.max_suggestions or 10
        )
        
        # Formater les suggestions
        formatted_suggestions = []
        for sugg in suggestions:
            if isinstance(sugg, str):
                formatted_suggestions.append(Suggestion(
                    text=sugg,
                    score=0.95,
                    reference="Auto-généré"
                ))
            else:
                formatted_suggestions.append(sugg)
        
        logger.info(f"✅ {len(formatted_suggestions)} suggestions trouvées")
        
        return AutocompleteResponse(
            query=request.query,
            suggestions=formatted_suggestions,
            count=len(formatted_suggestions)
        )
        
    except Exception as e:
        logger.error(f"❌ Erreur autocomplete: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/reformulate", response_model=ReformulateResponse)
async def reformulate_observation(
    request: ReformulateRequest,
    pipeline = Depends(get_correction_pipeline)
):
    """
    Reformuler une observation électrique avec l'IA
    
    - **text**: Observation brute à reformuler
    - **location**: Localisation optionnelle (ex: "Cuisine")
    """
    try:
        logger.info(f"✨ Reformulation: '{request.text[:50]}...'")
        
        if not request.text.strip():
            raise HTTPException(status_code=400, detail="Texte vide")
        
        # Ajouter localisation si fournie
        text = request.text
        if request.location:
            text = f"{text} - Localisation: {request.location}"
        
        result = pipeline.corriger_observation(text)
        
        logger.info(f"✅ Reformulation terminée")
        
        return ReformulateResponse(
            original_text=request.text,
            reformulated_text=result.get('observation_corrigee', ''),
            severity=result.get('niveau_gravite', 'Non spécifié'),
            recommended_delay=result.get('delai_recommande', 'Non spécifié'),
            normative_references=result.get('references_normatives', [])
        )
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erreur reformulation: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/extract_norme", response_model=NormeResponse)
async def extract_norme(
    request: NormeRequest,
    prescriptions = Depends(get_prescriptions)
):
    """
    Extraire la norme NFC 15-100 correspondante
    
    - **observation**: Observation électrique à analyser
    """
    try:
        logger.info(f"📚 Extraction norme: '{request.observation[:50]}...'")
        
        if not request.observation.strip():
            raise HTTPException(status_code=400, detail="Observation vide")
        
        # Import ici pour éviter dépendances circulaires
        from norme_lookup import get_norme_from_db
        
        norme = get_norme_from_db(request.observation, prescriptions)
        
        logger.info(f"✅ Norme extraite")
        
        return NormeResponse(
            observation=request.observation,
            norme=norme
        )
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erreur extraction norme: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/search", response_model=SearchResponse)
async def search_documents(
    request: SearchRequest,
    vector_store = Depends(get_vector_store)
):
    """
    Recherche sémantique dans les 749 documents
    
    - **query**: Question ou recherche
    - **top_k**: Nombre de résultats (défaut: 5, max: 20)
    """
    try:
        logger.info(f"🔍 Recherche: '{request.query}'")
        
        if not request.query.strip():
            raise HTTPException(status_code=400, detail="Query vide")
        
        top_k = min(request.top_k or 5, 20)
        
        results = vector_store.search(
            query=request.query,
            top_k=top_k
        )
        
        logger.info(f"✅ {len(results)} documents trouvés")
        
        return SearchResponse(
            query=request.query,
            results=results,
            count=len(results)
        )
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erreur recherche: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.get("/status")
async def get_status():
    """Statut détaillé du système"""
    return {
        "status": "operational",
        "services": {
            "suggestion_engine": services.suggestion_engine is not None,
            "correction_pipeline": services.correction_pipeline is not None,
            "vector_store": services.vector_store is not None,
            "prescriptions_loaded": services.prescriptions is not None and len(services.prescriptions) > 0
        },
        "stats": {
            "prescriptions_count": len(services.prescriptions) if services.prescriptions else 0,
            "vector_store_docs": services.vector_store.index.ntotal if services.vector_store and hasattr(services.vector_store, 'index') else 0
        }
    }